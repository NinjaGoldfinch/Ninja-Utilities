{
  "schemaVersion": 1,
  "id": "ninja_utils",
  "version": "${version}",

  "name": "Ninja Utilities",
  "description": "QoL Hypixel Skyblock Mod",
  "authors": [],
  "contact": {},

  "license": "LGPL-3.0",
  "icon": "assets/ninja_utils/icon.png",

  "environment": "client",
  "entrypoints": {
    "client": [
      { "adapter": "kotlin", "value": "com.ninjagoldfinch.nz.ninja_utils.client.NinjaUtilsClient" }
    ],
    "main": [
      { "adapter": "kotlin", "value": "com.ninjagoldfinch.nz.ninja_utils.NinjaUtils" }
    ]
  },

  "mixins": [
    "ninja_utils.mixins.json",
    {
      "config": "ninja_utils.client.mixins.json",
      "environment": "client"
    }
  ],

  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-language-kotlin": ">=${kotlin_loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  },
  "suggests": {
    "hypixel-mod-api": ">=1.0"
  }
}
